# Database – use a real connection string in .env
# PostgreSQL (e.g. Neon, Supabase, Railway, local):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# SQLite (optional, for local dev without Postgres):
# DATABASE_URL="file:./dev.db"

DATABASE_URL="postgresql://user:password@localhost:5432/vibecircle?schema=public"
